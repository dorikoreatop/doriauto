-- [[ 핵심: 팀원 감시 및 자동 리셋 로직 ]] --
task.spawn(function()
    while true do
        if teamResetEnabled and isAutoFarming then
            local teammatesAlive = false
            local otherPlayers = 0
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player then
                    otherPlayers = otherPlayers + 1
                    -- 팀원의 캐릭터가 존재하고 체력이 0보다 큰지 확인
                    if p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                        teammatesAlive = true
                    end
                end
            end
            
            -- 서버에 나 말고 다른 사람이 있는데, 살아있는 사람이 한명도 없다면 리셋
            if otherPlayers > 0 and not teammatesAlive then
                Rayfield:Notify({Title = "팀원 사망 감지", Content = "동료가 모두 죽어 리셋합니다.", Duration = 2})
                if player.Character and player.Character:FindFirstChild("Humanoid") then
                    player.Character.Humanoid.Health = 0 -- 즉시 자살
                end
                task.wait(5) -- 리셋 후 딜레이
            end
        end
        task.wait(1)
    end
end)

