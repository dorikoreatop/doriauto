local function sendKey(key)
    VIM:SendKeyEvent(true, key, false, game)
    task.wait(0.01)
    VIM:SendKeyEvent(false, key, false, game)
end

-- [[ 로직 1: 난이도 좌표 클릭/스크롤 (기존 동일) ]] --
task.spawn(function()
    while true do
        if autoSelectDifficulty and not currentTarget then
            pcall(function()
                local targetX, targetY = 768, 396
                if selectedDifficulty == "쉬움" then
                    VIM:SendMouseButtonEvent(targetX, targetY + 36, 0, true, game, 0)
                    task.wait(0.05)
                    VIM:SendMouseButtonEvent(targetX, targetY + 36, 0, false, game, 0)
                elseif selectedDifficulty == "노말" then
                    VIM:SendMouseWheelEvent(targetX, targetY + 36, false, game)
                    task.wait(0.2)
                    VIM:SendMouseButtonEvent(targetX, targetY + 36, 0, true, game, 0)
                    task.wait(0.05)
                    VIM:SendMouseButtonEvent(targetX, targetY + 36, 0, false, game, 0)
                elseif selectedDifficulty == "하드" then
                    for i=1, 2 do VIM:SendMouseWheelEvent(targetX, targetY + 36, false, game) task.wait(0.1) end
                    VIM:SendMouseButtonEvent(targetX, targetY + 36, 0, true, game, 0)
                    task.wait(0.05)
                    VIM:SendMouseButtonEvent(targetX, targetY + 36, 0, false, game, 0)
                end
            end)
        end
        task.wait(currentTarget and 3 or 1.5)
    end
end)

-- [[ 로직 2: 사냥/에임/미세 움직임 고정 (기존 동일) ]] --
RunService.RenderStepped:Connect(function()
    if not isAutoFarming then return end
    local char = player.Character
    if not (char and char:FindFirstChild("HumanoidRootPart")) then return end
    local root = char.HumanoidRootPart
    
    hoverTick = hoverTick + (1/60 * hoverSpeed)
    local yOffset = math.sin(hoverTick) * hoverAmplitude
    
    local mobs = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Humanoid") and v.Parent:FindFirstChild("HumanoidRootPart") then
            local mchar = v.Parent
            if mchar.Name ~= player.Name and not Players:GetPlayerFromCharacter(mchar) and v.Health > 0 then
                local dist = (root.Position - mchar.HumanoidRootPart.Position).Magnitude
                if dist <= mobDetectionRange then table.insert(mobs, mchar) end
            end
        end
    end
    
    if #mobs > 0 then
        if not currentTarget or not currentTarget:FindFirstChild("Humanoid") or currentTarget.Humanoid.Health <= 0 then
            currentTarget = mobs[1]
        end
        if currentTarget and currentTarget:FindFirstChild("HumanoidRootPart") then
            local targetPos = currentTarget.HumanoidRootPart.Position + (currentTarget.HumanoidRootPart.CFrame.LookVector * -followDistance)
            root.CFrame = CFrame.new(targetPos + Vector3.new(0, yOffset, 0), currentTarget.HumanoidRootPart.Position)
            if aimbotEnabled then
                camera.CFrame = CFrame.new(camera.CFrame.Position, currentTarget.HumanoidRootPart.Position)
            end
        end
    else
        currentTarget = nil
        root.CFrame = CFrame.new(waitingPos + Vector3.new(0, yOffset, 0))
    end
end)

