-- [[ 사냥/이동/에임봇 (순환 타겟팅 적용) ]] --
RunService.RenderStepped:Connect(function()
    if not isAutoFarming then return end
    local char = player.Character
    if not (char and char:FindFirstChild("HumanoidRootPart")) then return end
    local root = char.HumanoidRootPart
    
    if char.Humanoid.Health > 0 then
        local distFromWait = (root.Position - waitingPos).Magnitude
        if distFromWait < 150 then
            root.CFrame = CFrame.new(waitingPos)
            currentTarget = nil
        else
            local mobs = {}
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Humanoid") and v.Parent:FindFirstChild("HumanoidRootPart") then
                    local mchar = v.Parent
                    if mchar.Name ~= player.Name and not Players:GetPlayerFromCharacter(mchar) and v.Health > 0 then
                        local dist = (root.Position - mchar.HumanoidRootPart.Position).Magnitude
                        if dist <= mobDetectionRange then table.insert(mobs, mchar) end
                    end
                end
            end
            
            if #mobs > 0 then
                if not currentTarget or not currentTarget:FindFirstChild("Humanoid") or currentTarget.Humanoid.Health <= 0 then
                    targetIndex = (targetIndex % #mobs) + 1
                    currentTarget = mobs[targetIndex]
                end
            else
                currentTarget = nil
            end

            if currentTarget and currentTarget:FindFirstChild("HumanoidRootPart") then
                root.CFrame = CFrame.new(currentTarget.HumanoidRootPart.Position + (currentTarget.HumanoidRootPart.CFrame.LookVector * -followDistance), currentTarget.HumanoidRootPart.Position)
            end
        end
    end
end)

