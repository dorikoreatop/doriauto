-- [[ 로직 4: 스킬 콤보 (평타 루프와 별개 작동) ]] --
task.spawn(function()
    while true do
        if isAutoFarming and currentTarget then
            pcall(function()
                -- [1번 무기]
                sendKey(Enum.KeyCode.One)
                task.wait(0.1)
                sendKey(Enum.KeyCode.Z); task.wait(0.1)
                sendKey(Enum.KeyCode.X); task.wait(0.1)
                sendKey(Enum.KeyCode.C); task.wait(0.1)
                -- 1번에 V는 절대 사용 안함

                -- [2번 무기]
                sendKey(Enum.KeyCode.Two)
                task.wait(0.1)
                sendKey(Enum.KeyCode.Z); sendKey(Enum.KeyCode.X)
                task.wait(0.1)

                -- [3번 무기]
                sendKey(Enum.KeyCode.Three)
                task.wait(0.1)
                sendKey(Enum.KeyCode.Z); sendKey(Enum.KeyCode.X); sendKey(Enum.KeyCode.C)
                sendKey(Enum.KeyCode.V); sendKey(Enum.KeyCode.E); sendKey(Enum.KeyCode.R)
                task.wait(0.1)
            end)
        end
        task.wait(0.2)
    end
end)

-- 팀원 재설정 로직 유지
task.spawn(function()
    while true do
        if teamResetEnabled and isAutoFarming then
            local teammatesAlive = false
            local otherPlayers = 0
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player then
                    otherPlayers = otherPlayers + 1
                    if p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then teammatesAlive = true end
                end
            end
            if otherPlayers > 0 and not teammatesAlive then
                if player.Character and player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid.Health = 0 end
                task.wait(5)
            end
        end
        task.wait(1)
    end
end)

